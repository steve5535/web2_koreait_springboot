<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.study.koreait.mapper.PostMapper">
    <!--  ResultMap  -->
    <!--  select кІ°кіјлҘј мһҗл°”мқҳ м–ҙл–Ө нғҖмһ…мңјлЎң л§Өм№ӯн• кұҙм§Җ м •мқҳн•ҳлҠ” кІғ  -->
    <resultMap id="postMap" type="com.study.koreait.entity.Post">
        <!--    pkл§Өн•‘    -->
        <id property="postId" column="post_id" />
        <!--   кё°ліён•„л“ң л§Өн•‘     -->
        <result property="title" column="title" />
        <result property="content" column="content" />
        <result property="createAt" column="create_at" />
        <result property="userId" column="user_id"/>
        <!--   1:N кҙҖкі„ л§Өн•‘     -->
        <collection property="comments" resultMap="commentsMap" javaType="list" />
    </resultMap>

    <!--  commentsмқҳ resultMap  -->
    <resultMap id="commentsMap" type="com.study.koreait.entity.Comments">
        <id property="commentId" column="comment_id" />
        <result property="body" column="body" />
        </resultMap>

    <!--  SQL   -->
    <select
        id="findAll"
        resultMap="postMap"
    >
        select * from post
    </select>

    <!--  left мЎ°мқён• л•Ң лҢ“кёҖмқҙ м—ҶлҠ” кІҢмӢңкёҖмқҖ л№ҲлҰ¬мҠӨнҠёлҘј л§Ңл“Өм–ҙмҳҙ  -->
    <select
            id="findAllPostsWithComments"
            resultType="com.study.koreait.entity.Post"
    >
        select
            p.post_id,
            p.title,
            p.content,
            p.create_at,
            c.comment_id,
            c.author,
            c.body
        from post p
        left join comments c on p.post_id = c.post_id
        order by p.post_id, c.comment_id
    </select>

    <insert id="insertPost">
        insert into
            post (title, content)
        values
            (#{title}, #{content})
    </insert>

    <insert id="insertPosts">
        insert into
            post(title, content)
        values
            <foreach
                    collection="posts"
                    item="post"
                    separator=","
            >
                (#{post.title}, #{post.content})
            </foreach>
    </insert>

    <!--  л§Өк°ңліҖмҲҳ мқҙлҰ„мқ„ ${}м—җ мһ‘м„ұк°ҖлҠҘ  -->
    <delete id="deletePostById">
        delete from
            post
        where
            post_id = #{id}
    </delete>

    <select id="detailSearchPosts" resultType="Post">
        select
            *
        from
            post
        where
            1=1
        <if test="titleKeyword != null and titleKeyword != ''">
            and title like concat('', #{titleKeyword}, '')
        </if><if test="contentKeyword != null and contentKeyword != ''">
            and title like concat('', #{contentKeyword}, '')
        </if>
        order by
            create_at desc
    </select>
    
    <select id="findPage" resultType="Post">
        select
            *
        from
            post
        order by
            create_at desc
        limit #{size} offset #{offset}
    </select>

    <select id="countAll" resultType="long">
        select
            count(*)
        from
            post
    </select>

    <select id="findPostsByUserId" resultMap="postMap">
        select
            p.post_id,
            p.title,
            p.content,
            p.create_at,
            c.comment_id,
            c.body
        from
            (
            select
                *
            from
                post
            where
                user_id = #{userId}
            <if test="from != null">
                and create_at &gt;= #{from}
            </if>
            <if test="to != null">
                and create_at &lt; #{to}
            </if>
            order by
                create_at desc
            limit #{size} offset #{offset}
        ) p
        left join comments c on p.post_id = c.post_id
        order by
            p.create_at desc, c.comment_id

    </select>

    <!--  мң м Җмқҳ кІҢмӢңкёҖмқ„ мөңмӢ мҲңмңјлЎң нҺҳмқҙм§Җл„Өмқҙм…ҳ, к°Ғ кІҢмӢңкёҖм—җлҠ” лҢ“кёҖл“ӨлҸ„ к°ҷмқҙ  -->
    <select id="countPostsByUserId" resultType="long">
        select
            count(*)
        from
            post
        where
            user_id = #{userId}
        <if test="from != null">
            and create_at &gt;= #{from}
        </if>
        <if test="to != null">
            and create_at &lt; #{to}
        </if>
    </select>



</mapper>